void loop () {
  checkForRequests();
  switch (currentState) {
    case IDLE:
      stopRobot();
      break;

    case MOVING_TO_TARGET:
      followLineSimple();

      if (checkIntersectionEvent()){
        stopRobot();
        delay(150); // pause so the event is stable;
        Serial.println("Handle target navigation here");
      }
      break;

    case DELIVERING:
      stopRobot();
      break;

    case RETURNING_HOME:
      followLineSimple();
      if (checkIntersectionEvent()) {
        Serial.println("Intersection while returning");
      // eventually will have something to update current location and to decide next move
      
  }

}
