#define TRIG_PIN // needs pin numbers 
#define ECHO_PIN // needs pin numbers

#define ENA 5
#define ENB 6
#define IN1 7
#define IN2 8
#define IN3 9
#define IN4 11
#define PWM 3
#define LT_RIGHT 10
#define LT_MIDDL 4
#define LT_LEFT 2

int lastTurn = 0;

Servo servo;

//time durations robot needs to turn ms
const int d90 = 632;
const int d180 = 1275;

//---------------GRID COORDINATES----------------
struct coordinate {
  int x;
  int y;
};

enum Direction {
  NORTH,
  EAST,
  SOUTH,
  WEST};

coordinate locations[9] = {
  {0,0},//hub
  {1,0},//1
  {2,0},//2
  {3,0},//3
  {4,0},//4
  {1,1},//5
  {2,1},//6
  {3,1},//7
  {4,1}//8
};

Direction currentDirection = NORTH;
//-------------DELIVERY SYSTEM-----------------
struct DeliveryRequest {
  int location;
  unsigned long timeAdded;
};

DeliveryRequest requestQueue[10];
int queueSize = 0;

enum State {
  IDLE,
  MOVING_TO_TARGET,
  DELIVERING,
  RETURNING_HOME
};

State currentState = IDLE;

int currentTarget = -1;
int currentLocation = 0;
int passedIntersections = 0;

bool onIntersection = false;
unsigned long deliveryStartTime = 0;

//-------PRIORITY-----------------------------
int getGridDistance(int fromLocation, int toLocation) {
  int x1 = locations[fromLocation].x;
  int y1 = locations[fromLocation].y;
  int x2 = locations[toLocation].x;
  int y2 = locations[toLocation].y;

  return abs(x1 - x2_ + abs(y1 - y2);
}

int chooseNextRequest() {
  int bestIndex = 0;
  int bestDistance = getGridDistance(currentLocation, requestQueue[0].location);
  unsigned long oldestTime = requestQueue[0].timeAdded;

  for (int i = 1; i < queueSize; i++) {
    int candidateLocation = requestQueue[i].location;
    int candidateDistance = getGridDistance(currentLocation, candidateLocation);
    unsigned long candidateTime = requestQueue[i].timeAdded;

    if (candidateDistance < bestDistance) {
      bestIndex = i;
      bestDistance = candidateDistance;
      oldestTime = candidateTime;
    }

    else if (candidateDistance = bestDistance && candidateTime < oldestTime) {
      bestIndex = i;
      oldestTime = candidateTime;
    }
  }
  return bestIndex;
}

//-------------SETUP--------------------
void setup() {
  Serial.begin(9600);
  Dabble.begin(9600);

  servo.attach(PWM);
  servo.write(90);

  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  digitalWrite(TRIG_PIN, LOW);

  pinMode(LT_LEFT, INPUT);
  pinMode(LT_MIDDL, INPUT);
  pinMode(LT_RIGHT, INPUT);

  Serial.println("Delivery robot started");
}

//--------------MOTOR FUNCTIONS-----------------
void moveForward(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void turnLeft(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void turnRight(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}

void stopRobot() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

void turnLeft90() {
  turnLeft(150, 150);
  delay(d90);
  stopRobot();
}

void turnRight90() {
  turnRight(150, 150);
  delay(d90);
  stopRobot();
}

void turn180() {
  turnLeft(150, 150);
  delay(d180);
  stopRobot();
}

//------------REQUEST QUEUE--------------------
void addRequest(int location) {
  if(queueSize >= 10) {
    Serial.println("Queue full");
    return;
  }
  for (int i = 0; i < queueSize; i+++ {
    if (requestQueue[i].location == location) {
      Serial.print("Intersection ");
      Serial.print(location);
      Serial.println(" already in queue");
      return;
    }
  }

  if (currentState == MOVING_TO_TARGET && currentTarget == location) {
    Serial.print("Already heading to intersection ");
    Serial.println(location);
    return;
  }

  requestQueue[queueSize].location = location;
  requestQueue[queueSize].timeAdded = millis();
  queueSize++;

  Serial.print("Added request for intersection ");
  Serial.println(location);

  printQueue();
}

void removeRequest(int index) {
  for (int i = index; i < queueSize - 1; i++) {
    requestQueue[i] = requestQueue[i + 1];
  }
  queueSize--;
}

void printQueue() {
  Serial.print("Queue: ");

  if (queueSize == 0) {
    Serial.println("empty");
    return;
  }

  for (int i = 0; i < queueSize; i++) {
    Serial.print(requestQueue[i].location);
    Serial.print(" ");
  }
  Serial.println();
}

//-------------------DABBLE BUTTON INPUT------------------

//up = intersection 1
//down = intersection 2
//left = intersection 3
//right = intersection 4
//triangle = intersection 5
//circle = intersection 6
//cross = intersection 7
//square = intersection 8

void checkForRequests() {
  Dabble.processInput();

  bool upNow = GamePad.isUpPressed();
  bool downNow = GamePad.isDownPressed();
  bool leftNow = GamePad.isLeftPressed();
  bool rightNow = GamePad.isRightPressed();
  bool triangleNow = GamePad.isTrianglePressed();
  bool circleNow = GamePad.isCirclePressed();
  bool crossNow = GamePad.isCrossPressed();
  bool squareNow = GamePad.isSquarePressed();

  if (upNow) addRequest(1);
  if (downNow) addRequest(2);
  if (leftNow) addRequest(3);
  if (rightNow) addRequest(4);
  if (triangleNow) addRequest(5);
  if (circleNow) addRequest(6);
  if (crossNow) addRequest(7);
  if (squareNow) addRequest(8);
}

//--------------------LINE FOLLOWING-----------------------
void followLineSimple() {
  int L = digitalRead(LT_LEFT);
  int M = digitalRead(LT_MIDDL);
  int R = digitalRead(LT_RIGHT);

  if (L == 0 && R == 1) {
    turnLeft(150, 150);
    lastTurn = 1;
  }
  else if (R == 0 && L == 1) {
    turnRight(150, 150);
    lastTurn = 2;
  }
  else if (M == 0) {
    moveForward(150, 150);
  }
  else if (L == 1 && R == 1 && M == 1) {
    if (lastTurn == 1) {
      turnLeft(150, 150);
    }
    else if (lastTurn == 2) {
      turnRight(150, 150);
    }
    else {
      stopRobot();
    }
  }
  else {
    stopRobot();
  }
}

//-------------------INTERSECTION DETECTION----------------------

// helper functions: true means that sensor is currently on the black line
bool leftOnLine() {
  return digitalRead(LT_LEFT) == 0;
}

bool middleOnLine() {
  return digitalRead(LT_MIDDL) == 0;
}

bool rightOnLine() {
  return digitalRead(LT_RIGHT) == 0;
}

// returns true if robot is physically over an intersection
// first version: all three sensors must see black
bool detectIntersection() {
  bool L = leftOnLine();
  bool M = middleOnLine();
  bool R = rightOnLine();

  return (L && M && R);
}

// to see sensor values in Serial Monitor
void printLineSensors() {
  Serial.print("L: ");
  Serial.print(digitalRead(LT_LEFT));
  Serial.print("  M: ");
  Serial.print(digitalRead(LT_MIDDL));
  Serial.print("  R: ");
  Serial.println(digitalRead(LT_RIGHT));
}

// this creates a one-time "event" when entering an intersection
// it prevents the same intersection from being counted repeatedly
bool checkIntersectionEvent() {
  bool atIntersection = detectIntersection();

  // robot has just arrived at a new intersection
  if (atIntersection && !onIntersection) {
    onIntersection = true;
    passedIntersections++;

    Serial.print("Intersection detected. Count = "); // visual assist
    Serial.println(passedIntersections);

    return true;
  }

  // robot has fully left the intersection area
  if (!atIntersection && onIntersection) {
    onIntersection = false;
  }

  return false;
}

//-------------------DIRECTION UPDATE---------------------------
void updateDirectionAfterLeftTurn() {
  if (currentDirection == NORTH) currentDirection = WEST;
  else if (currentDirection == WEST) currentDirection = SOUTH;
  else if (currentDirection == SOUTH) currentDirection = EAST;
  else if (currentDirection == EAST) currentDirection = NORTH;
}

void updateDirectionAfterRightTurn() {
  if (currentDirection == NORTH) currentDirection = EAST;
  else if (currentDirection == EAST) currentDirection = SOUTH;
  else if (currentDirection == SOUTH) currentDirection = WEST;
  else if (currentDirection == WEST) currentDirection = NORTH;
}

void updateDirectionAfter180Turn() {
  if (currentDirection == NORTH) currentDirection = SOUTH;
  else if (currentDirection == SOUTH) currentDirection = NORTH;
  else if (currentDirection == EAST) currentDirection = WEST;
  else if (currentDirection == WEST) currentDirection = EAST;
}

void turnToDirection(Direction targetDirection) {
  while (currentDirection != targetDirection) {
    // always turn right until aligned
    turnRight90();
    updateDirectionAfterRightTurn();

    Serial.print("Turned. Now facing: ");
    Serial.println(currentDirection);
  }
}

