  bool leftNow = GamePad.isLeftPressed();
  bool rightNow = GamePad.isRightPressed();
  bool triangleNow = GamePad.isTrianglePressed();
  bool circleNow = GamePad.isCirclePressed();
  bool crossNow = GamePad.isCrossPressed();
  bool squareNow = GamePad.isSquarePressed();

  if (upNow) addRequest(1);
  if (downNow) addRequest(2);
  if (leftNow) addRequest(3);
  if (rightNow) addRequest(4);
  if (triangleNow) addRequest(5);
  if (circleNow) addRequest(6);
  if (crossNow) addRequest(7);
  if (squareNow) addRequest(8);
}

//--------------------LINE FOLLOWING-----------------------
void followLineSimple() {
  int L = digitalRead(LT_LEFT);
  int M = digitalRead(LT_MIDDL);
  int R = digitalRead(LT_RIGHT);

  if (L == 0 && R == 1) {
    turnLeft(150, 150);
    lastTurn = 1;
  }
  else if (R == 0 && L == 1) {
    turnRight(150, 150);
    lastTurn = 2;
  }
  else if (M == 0) {
    moveForward(150, 150);
  }
  else if (L == 1 && R == 1 && M == 1) {
    if (lastTurn == 1) {
      turnLeft(150, 150);
    }
    else if (lastTurn == 2) {
      turnRight(150, 150);
    }
    else {
      stopRobot();
    }
  }
  else {
    stopRobot();
  }
}

