#define CUSTOM_SETTINGS
#define INCLUDE_GAMEPAD_MODULE

#include <Servo.h>
#include <Dabble.h>

#define TRIG_PIN 12
#define ECHO_PIN 13

#define ENA 5
#define ENB 6
#define IN1 7
#define IN2 8
#define IN3 9
#define IN4 11
#define PWM 3
#define LT_RIGHT 10
#define LT_MIDDL 4
#define LT_LEFT 2

#define MAX_QUEUE 8

Servo servo;
int lastTurn = 0;

struct Coordinate {
  int x;
  int y;
};

enum Direction {
  NORTH,
  EAST,
  SOUTH,
  WEST
};

enum RobotState {
  ADD_DELIVERY,
  MOVING_TO_TARGET,
  DELIVERING,
  RETURN_HOME,
};

RobotState currentState = ADD_DELIVERY;

Coordinate currentPos = {1, 0};   // home starts at (1,0)
Coordinate homePos = {1, 0};
Coordinate currentTarget;

Direction currentDirection = EAST;

Coordinate deliveryQueue[MAX_QUEUE];
int queueSize = 0;

bool onIntersection = false;
bool hasTarget = false;

// ---------------- QUEUE FUNCTIONS ----------------
void printQueue() {
  Serial.print("Queue: ");

  if (queueSize == 0) {
    Serial.println("empty");
    return;
  }

  for (int i = 0; i < queueSize; i++) {
    Serial.print("(");
    Serial.print(deliveryQueue[i].x);
    Serial.print(",");
    Serial.print(deliveryQueue[i].y);
    Serial.print(") ");
  }

  Serial.println();
}

void enqueue(Coordinate coord) {
  if (queueSize >= MAX_QUEUE) {
    Serial.println("Queue FULL. Cannot add more than 8 deliveries.");
    return;
  }

  deliveryQueue[queueSize] = coord;
  queueSize++;

  Serial.print("Added delivery: (");
  Serial.print(coord.x);
  Serial.print(",");
  Serial.print(coord.y);
  Serial.println(")");

  printQueue();
}

Coordinate dequeue() {
  Coordinate first = deliveryQueue[0];

  for (int i = 0; i < queueSize - 1; i++) {
    deliveryQueue[i] = deliveryQueue[i + 1];
  }

  queueSize--;
  printQueue();

  return first;
}
//ADDED
int distanceBetween(Coordinate a, Coordinate b) {
  return abs(a.x - b.x) + abs(a.y - b.y);
}

void prioritizeQueueByDistance(Coordinate startPos) {
  Coordinate tempPos = startPos;

  for (int i = 0; i < queueSize - 1; i++) {
    int closestIndex = i;
    int closestDistance = distanceBetween(tempPos, deliveryQueue[i]);

    for (int j = i + 1; j < queueSize; j++) {
      int d = distanceBetween(tempPos, deliveryQueue[j]);

      if (d < closestDistance) {
        closestDistance = d;
        closestIndex = j;
      }
    }

    if (closestIndex != i) {
      Coordinate temp = deliveryQueue[i];
      deliveryQueue[i] = deliveryQueue[closestIndex];
      deliveryQueue[closestIndex] = temp;
    }

    tempPos = deliveryQueue[i];
  }

  Serial.println("Queue prioritized by closest distance:");
  printQueue();
}
// ---------------- DABBLE INPUT ----------------
void checkForQueueInput() {
  Dabble.processInput();

  if (GamePad.isDownPressed()) {
    enqueue({2, 0});
    delay(300);
  }

  if (GamePad.isLeftPressed()) {
    enqueue({3, 0});
    delay(300);
  }

  if (GamePad.isRightPressed()) {
    enqueue({4, 0});
    delay(300);
  }

  if (GamePad.isTrianglePressed()) {
    enqueue({1, 1});
    delay(300);
  }

  if (GamePad.isCirclePressed()) {
    enqueue({2, 1});
    delay(300);
  }

  if (GamePad.isCrossPressed()) {
    enqueue({3, 1});
    delay(300);
  }

  if (GamePad.isSquarePressed()) {
    enqueue({4, 1});
    delay(300);
  }
}

bool startButtonPressed() {
  Dabble.processInput();

  if (GamePad.isUpPressed()) {
    delay(300);
    return true;
  }

  return false;
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(9600);
  Dabble.begin(9600, 0, 1);

  servo.attach(PWM);
  servo.write(90);

  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  digitalWrite(TRIG_PIN, LOW);

  pinMode(LT_LEFT, INPUT);
  pinMode(LT_MIDDL, INPUT);
  pinMode(LT_RIGHT, INPUT);

  pinMode(13, OUTPUT); //LED
  digitalWrite(13, LOW);

  Serial.println("Robot started in ADD_DELIVERY state.");
  Serial.println("Add deliveries, then press UP to start.");
}

// ---------------- MOTOR FUNCTIONS ----------------
void moveForward(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void turnLeft(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void turnRight(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}

void stopRobot() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

// ---------------- LINE FOLLOWING ----------------
void followLineSimple() {
  int L = digitalRead(LT_LEFT);
  int M = digitalRead(LT_MIDDL);
  int R = digitalRead(LT_RIGHT);

  if (L == 0 && R == 1) {
    turnLeft(150, 150);
    lastTurn = 1;
  }
  else if (R == 0 && L == 1) {
    turnRight(150, 150);
    lastTurn = 2;
  }
  else if (M == 0) {
    moveForward(150, 150);
  }
  else if (L == 1 && R == 1 && M == 1) {
    if (lastTurn == 1) {
      turnLeft(150, 150);
    }
    else if (lastTurn == 2) {
      turnRight(150, 150);
    }
    else {
      moveForward(100, 100);
    }
  }
  else {
    moveForward(100, 100);
  }
}

// ---------------- SENSOR HELPERS ----------------
bool leftOnLine() {
  return digitalRead(LT_LEFT) == 0;
}

bool middleOnLine() {
  return digitalRead(LT_MIDDL) == 0;
}

bool rightOnLine() {
  return digitalRead(LT_RIGHT) == 0;
}

bool detectIntersection() {
  return leftOnLine() && middleOnLine() && rightOnLine();
}

bool checkIntersectionEvent() {
  bool atIntersection = detectIntersection();

  if (atIntersection && !onIntersection) {
    onIntersection = true;
    return true;
  }

  if (!atIntersection && onIntersection) {
    onIntersection = false;
  }

  return false;
}

// ---------------- DIRECTION HELPERS ----------------
void updateAfterLeftTurn() {
  if (currentDirection == NORTH) currentDirection = WEST;
  else if (currentDirection == WEST) currentDirection = SOUTH;
  else if (currentDirection == SOUTH) currentDirection = EAST;
  else if (currentDirection == EAST) currentDirection = NORTH;
}

void updateAfterRightTurn() {
  if (currentDirection == NORTH) currentDirection = EAST;
  else if (currentDirection == EAST) currentDirection = SOUTH;
  else if (currentDirection == SOUTH) currentDirection = WEST;
  else if (currentDirection == WEST) currentDirection = NORTH;
}

void updateAfter180Turn() {
  if (currentDirection == NORTH) currentDirection = SOUTH;
  else if (currentDirection == SOUTH) currentDirection = NORTH;
  else if (currentDirection == EAST) currentDirection = WEST;
  else if (currentDirection == WEST) currentDirection = EAST;
}

Direction getNeededDirection(Coordinate from, Coordinate to) {
  if (to.x > from.x) return EAST;
  if (to.x < from.x) return WEST;
  if (to.y > from.y) return NORTH;
  return SOUTH;
}

bool sameCoordinate(Coordinate a, Coordinate b) {
  return a.x == b.x && a.y == b.y;
}

Coordinate getNextStepToward(Coordinate from, Coordinate to) {
  Coordinate next = from;

  if (to.x > from.x) next.x++;
  else if (to.x < from.x) next.x--;
  else if (to.y > from.y) next.y++;
  else if (to.y < from.y) next.y--;

  return next;
}

// ---------------- CLEAR INTERSECTION ----------------
void clearIntersection() {
  moveForward(150, 150);
  delay(350);
  stopRobot();
  delay(150);

  onIntersection = false;
}

// ---------------- COMMITTED TURNING ----------------
void turnLeftCommitted() {
  // Serial.println("Decision: committed left turn");

  stopRobot();
  delay(150);

  moveForward(150, 150);
  delay(350); //values to be messed with
  stopRobot();
  delay(150);

  turnLeft(180, 180);
  delay(775); //values to be messed with
  stopRobot();
  delay(100);

  unsigned long startTime = millis();

  while (!middleOnLine() && millis() - startTime < 1500) {
    turnLeft(120, 120);
  }

  stopRobot();
  delay(150);

  moveForward(130, 130);
  delay(150);
  stopRobot();
  delay(100);

  updateAfterLeftTurn();
  lastTurn = 1;
  onIntersection = false;
}

void turnRightCommitted() {
  // Serial.println("Decision: committed right turn");

  stopRobot();
  delay(150);

  moveForward(150, 150);
  delay(350); //values to be messed with
  stopRobot();
  delay(150);

  turnRight(180, 180);
  delay(775); //values to be messed with
  stopRobot();
  delay(100);

  unsigned long startTime = millis();

  while (!middleOnLine() && millis() - startTime < 1500) {
    turnRight(120, 120);
  }

  stopRobot();
  delay(150);

  moveForward(130, 130);
  delay(150);
  stopRobot();
  delay(100);

  updateAfterRightTurn();
  lastTurn = 2;
  onIntersection = false;
}

void turnAroundCommitted() {
  // Serial.println("Decision: committed 180 turn");

  stopRobot();
  delay(150);

  turnLeft(170, 170);
  delay(1500);
  stopRobot();
  delay(100);

  unsigned long startTime = millis();

  while (!middleOnLine() && millis() - startTime < 1500) {
    turnLeft(120, 120);
  }

  stopRobot();
  delay(150);

  moveForward(130, 130);
  delay(150);
  stopRobot();
  delay(100);

  updateAfter180Turn();
  lastTurn = 1;
  onIntersection = false;
}

void turnToDirection(Direction targetDirection) {
  if (currentDirection == targetDirection) {
    Serial.println("Decision: go straight");
    return;
  }

  if ((currentDirection == EAST  && targetDirection == NORTH) ||
      (currentDirection == NORTH && targetDirection == WEST)  ||
      (currentDirection == WEST  && targetDirection == SOUTH) ||
      (currentDirection == SOUTH && targetDirection == EAST)) {
    turnLeftCommitted();
    return;
  }

  if ((currentDirection == EAST  && targetDirection == SOUTH) ||
      (currentDirection == SOUTH && targetDirection == WEST)  ||
      (currentDirection == WEST  && targetDirection == NORTH) ||
      (currentDirection == NORTH && targetDirection == EAST)) {
    turnRightCommitted();
    return;
  }

  turnAroundCommitted();
}

// ---------------- NAVIGATION HELPERS ----------------
void prepareNextMovement() {
  if (sameCoordinate(currentPos, currentTarget)) {
    stopRobot();
    return;
  }

  Coordinate nextStep = getNextStepToward(currentPos, currentTarget);

  Serial.print("Next step: (");
  Serial.print(nextStep.x);
  Serial.print(",");
  Serial.print(nextStep.y);
  Serial.println(")");

  Direction neededDirection = getNeededDirection(currentPos, nextStep);

  bool turning = currentDirection != neededDirection;

  turnToDirection(neededDirection);

  if (!turning) {
    clearIntersection();
  }
}

void handleReachedIntersection() {
  stopRobot();
  delay(800);

  Coordinate nextStep = getNextStepToward(currentPos, currentTarget);
  currentPos = nextStep;

  Serial.print("Reached: (");
  Serial.print(currentPos.x);
  Serial.print(",");
  Serial.print(currentPos.y);
  Serial.println(")");

  if (sameCoordinate(currentPos, currentTarget)) {
    Serial.println("Reached target.");
    stopRobot();

    if (currentState == MOVING_TO_TARGET) {
      currentState = DELIVERING;
    }
    else if (currentState == RETURN_HOME) {
      Serial.println("Returned home.");
      currentState = ADD_DELIVERY;
    }

    return;
  }

  prepareNextMovement();
}

// ---------------- DELIVERY ACTION ----------------
void performDelivery() {
  digitalWrite(13, HIGH);
  stopRobot();

  Serial.print("Delivering at: (");
  Serial.print(currentPos.x);
  Serial.print(",");
  Serial.print(currentPos.y);
  Serial.println(")");

  delay(2000);

  Serial.println("Delivery complete.");
  digitalWrite(13, LOW);
}

// ---------------- MAIN LOOP ----------------
void loop() {
  switch (currentState) {

    case ADD_DELIVERY:
      checkForQueueInput();

      if (startButtonPressed()) {
        if (queueSize > 0) {
          Serial.println("Starting deliveries.");
          prioritizeQueueByDistance(currentPos);//ADDED
          currentTarget = dequeue();
          hasTarget = true;
          currentState = MOVING_TO_TARGET;
          prepareNextMovement();
        }
        else {
          Serial.println("No deliveries in queue.");
        }
      }
      break;

    case MOVING_TO_TARGET:
      followLineSimple();

      if (checkIntersectionEvent()) {
        handleReachedIntersection();
      }
      break;

    case DELIVERING:
      performDelivery();

      if (queueSize > 0) {
        prioritizeQueueByDistance(currentPos);//ADDED
        currentTarget = dequeue();
        currentState = MOVING_TO_TARGET;
        prepareNextMovement();
      }
      else {
        Serial.println("Queue empty. Returning home.");
        currentTarget = homePos;
        currentState = RETURN_HOME;
        prepareNextMovement();
      }
      break;

    case RETURN_HOME:
      followLineSimple();

      if (checkIntersectionEvent()) {
        handleReachedIntersection();
      }
      break;
  }

  delay(10);
}

