#include <Servo.h>
#include <Dabble.h>

#define TRIG_PIN 12
#define ECHO_PIN 13

#define ENA 5
#define ENB 6
#define IN1 7
#define IN2 8
#define IN3 9
#define IN4 11
#define PWM 3
#define LT_RIGHT 10
#define LT_MIDDL 4
#define LT_LEFT 2

Servo servo;
int lastTurn = 0;

struct Coordinate {
  int x;
  int y;
};

enum Direction {
  NORTH,
  EAST,
  SOUTH,
  WEST
};

Coordinate currentPos = {0, 0};
Direction currentDirection = EAST;

Coordinate testPath[] = {
  {1, 0},
  {2, 0},
  {2, 1}
};

const int pathLength = 3;
int pathIndex = 0;

bool onIntersection = false;
bool finishedTest = false;

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(9600);
  Dabble.begin(9600);

  servo.attach(PWM);
  servo.write(90);

  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  digitalWrite(TRIG_PIN, LOW);

  pinMode(LT_LEFT, INPUT);
  pinMode(LT_MIDDL, INPUT);
  pinMode(LT_RIGHT, INPUT);

  Serial.println("Navigation test started");
  Serial.println("Path: (1,0) -> (2,0) -> (2,1)");
}

// ---------------- MOTOR FUNCTIONS ----------------
void moveForward(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void turnLeft(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}

void turnRight(int leftSpeed, int rightSpeed) {
  analogWrite(ENA, leftSpeed);
  analogWrite(ENB, rightSpeed);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}

void stopRobot() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

// ---------------- LINE FOLLOWING ----------------
void followLineSimple() {
  int L = digitalRead(LT_LEFT);
  int M = digitalRead(LT_MIDDL);
  int R = digitalRead(LT_RIGHT);

  if (L == 0 && R == 1) {
    turnLeft(150, 150);
    lastTurn = 1;
  }
  else if (R == 0 && L == 1) {
    turnRight(150, 150);
    lastTurn = 2;
  }
  else if (M == 0) {
    moveForward(150, 150);
  }
  else if (L == 1 && R == 1 && M == 1) {
    if (lastTurn == 1) {
      turnLeft(150, 150);
    }
    else if (lastTurn == 2) {
      turnRight(150, 150);
    }
    else {
      moveForward(100,100); //ADDED THIS, ROBOT KEEPS SEARCHING FOR LINE
    }
  }
  else {
    moveForward(100,100);  //ADDED THIS, ROBOT KEEPS SEARCHING FOR LINE
  }
}

// ---------------- SENSOR HELPERS ----------------
bool leftOnLine() {
  return digitalRead(LT_LEFT) == 0;
}

bool middleOnLine() {
  return digitalRead(LT_MIDDL) == 0;
}

bool rightOnLine() {
  return digitalRead(LT_RIGHT) == 0;
}

bool detectIntersection() {
  return leftOnLine() && middleOnLine() && rightOnLine();
}

bool checkIntersectionEvent() {
  bool atIntersection = detectIntersection();

  if (atIntersection && !onIntersection) {
    onIntersection = true;
    return true;
  }

  if (!atIntersection && onIntersection) {
    onIntersection = false;
  }

  return false;
}

// ---------------- DIRECTION HELPERS ----------------
void updateAfterLeftTurn() {
  if (currentDirection == NORTH) currentDirection = WEST;
  else if (currentDirection == WEST) currentDirection = SOUTH;
  else if (currentDirection == SOUTH) currentDirection = EAST;
  else if (currentDirection == EAST) currentDirection = NORTH;
}

void updateAfterRightTurn() {
  if (currentDirection == NORTH) currentDirection = EAST;
  else if (currentDirection == EAST) currentDirection = SOUTH;
  else if (currentDirection == SOUTH) currentDirection = WEST;
  else if (currentDirection == WEST) currentDirection = NORTH;
}

void updateAfter180Turn() {
  if (currentDirection == NORTH) currentDirection = SOUTH;
  else if (currentDirection == SOUTH) currentDirection = NORTH;
  else if (currentDirection == EAST) currentDirection = WEST;
  else if (currentDirection == WEST) currentDirection = EAST;
}

Direction getNeededDirection(Coordinate from, Coordinate to) {
  if (to.x > from.x) return EAST;
  if (to.x < from.x) return WEST;
  if (to.y > from.y) return NORTH;
  return SOUTH;
}

bool needToTurn(Direction targetDirection) {
  return currentDirection != targetDirection;
}

// ---------------- CLEAR INTERSECTION ----------------
void clearIntersection() {
  moveForward(150, 150);
  delay(350);
  stopRobot();
  delay(150);

  onIntersection = false;
}

// ---------------- COMMITTED TURNING ----------------
void turnLeftCommitted() {
  Serial.println("Decision: committed left turn");

  stopRobot();
  delay(150);

  //Move forward to clear the center of the intersection
  moveForward(150, 150);
  delay(250);
  stopRobot();
  delay(150);

  //Keep turning until middle sensor finds black line
  unsigned long startTime = millis();

  while (!middleOnLine() && millis() - startTime < 1500) {
    turnLeft(120, 120);
  }

  stopRobot();
  delay(150);

  // Small forward nudge to center onto the new path
  moveForward(130, 130);
  delay(150);
  stopRobot();
  delay(100);

  updateAfterLeftTurn();
  lastTurn = 1;
  onIntersection = false;
}

void turnRightCommitted() {
  Serial.println("Decision: committed right turn");

  stopRobot();
  delay(150);

  // move forward to clear the center of the intersection
  moveForward(150, 150);
  delay(250);
  stopRobot();
  delay(150);

  // start to turn right
  turnRight(170, 170);
  delay(600);  
  stopRobot();
  delay(100);

  //keep turning until middle sensor finds new line
  unsigned long startTime = millis();

  while (!middleOnLine() && millis() - startTime < 1500) {
    turnRight(120, 120);
  }

  stopRobot();
  delay(150);

  // Small forward nudge to center onto the new path
  moveForward(130, 130);
  delay(150);
  stopRobot();
  delay(100);

  updateAfterRightTurn();
  lastTurn = 2;
  onIntersection = false;
}

void turnAroundCommitted() {
  Serial.println("Decision: committed 180 turn");

  stopRobot();
  delay(150);

  turnLeft(170, 170);
  delay(1200);
  stopRobot();
  delay(100);

  unsigned long startTime = millis();

  while (!middleOnLine() && millis() - startTime < 2000) {
    turnLeft(120, 120);
  }

  stopRobot();
  delay(150);

  moveForward(130, 130);
  delay(150);
  stopRobot();
  delay(100);

  updateAfter180Turn();
  lastTurn = 1;
  onIntersection = false;
}

void turnToDirection(Direction targetDirection) {
  if (currentDirection == targetDirection) {
    Serial.println("Decision: go straight");
    return;
  }

  if ((currentDirection == EAST  && targetDirection == NORTH) ||
      (currentDirection == NORTH && targetDirection == WEST)  ||
      (currentDirection == WEST  && targetDirection == SOUTH) ||
      (currentDirection == SOUTH && targetDirection == EAST)) {
    turnLeftCommitted();
    return;
  }

  if ((currentDirection == EAST  && targetDirection == SOUTH) ||
      (currentDirection == SOUTH && targetDirection == WEST)  ||
      (currentDirection == WEST  && targetDirection == NORTH) ||
      (currentDirection == NORTH && targetDirection == EAST)) {
    turnRightCommitted();
    return;
  }

  turnAroundCommitted();
}

// ---------------- HANDLE INTERSECTION ----------------
void handleReachedIntersection() {
  stopRobot();
  delay(800);

  currentPos = testPath[pathIndex];

  Serial.print("Reached: (");
  Serial.print(currentPos.x);
  Serial.print(",");
  Serial.print(currentPos.y);
  Serial.println(")");

  pathIndex++;

  if (pathIndex >= pathLength) {
    Serial.println("Test complete");
    finishedTest = true;
    stopRobot();
    return;
  }

  Coordinate nextTarget = testPath[pathIndex];

  Serial.print("Next target: (");
  Serial.print(nextTarget.x);
  Serial.print(",");
  Serial.print(nextTarget.y);
  Serial.println(")");

  Direction neededDirection = getNeededDirection(currentPos, nextTarget);

  bool turning = needToTurn(neededDirection);

  turnToDirection(neededDirection);

  if (!turning) {
    clearIntersection();
  }
}

// ---------------- MAIN LOOP ----------------
void loop() {
  if (finishedTest) {
    stopRobot();
    return;
  }

  followLineSimple();

  if (checkIntersectionEvent()) {
    handleReachedIntersection();
  }

  delay(10);
}
